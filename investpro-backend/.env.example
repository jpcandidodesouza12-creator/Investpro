# ─── Copie este arquivo para .env e preencha os valores ───────────────────────
# NÃO suba o arquivo .env para o GitHub!

# PostgreSQL — Railway gera automaticamente
DATABASE_URL=postgresql://usuario:senha@host:5432/investpro

# JWT — gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cole_aqui_um_segredo_longo_e_aleatorio

# Seu e-mail de Admin Master (criado automaticamente no primeiro start)
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=sua_senha_forte_aqui
ADMIN_NAME=Admin

# Porta do servidor (Railway define automaticamente)
PORT=3001

# Origem do frontend (GitHub Pages ou localhost)
FRONTEND_URL=https://seuusuario.github.io
